# Telegram bot token (@BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Google Gemini API key (https://aistudio.google.com -> Get API key) — tekin, karta shart emas
GEMINI_API_KEY=

# Google Sheet ID (jadval URL'idan: docs.google.com/spreadsheets/d/<BU_QISM>/edit)
GOOGLE_SHEET_ID=

# Service account JSON yo'li (ixtiyoriy; bo'sh qolsangiz public Viewer share orqali ham ishlaydi)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Ish varag'i (tab) nomi
SHEET_NAME=Sheet1

# Admin Telegram ID(lar) — /reload va /settings uchun (vergul bilan): 12345678,87654321
ADMIN_IDS=

# Ixtiyoriy
CACHE_TTL=300
GEMINI_MODEL=gemini-2.0-flash
TEXNOMART_MAX_PAGES=16
TEXNOMART_MAX_ITEMS=80
TEXNOMART_CACHE_PATH=texnomart_cache.json
TEXNOMART_CACHE_TTL=1800

# Abuse/dump himoyasi (ixtiyoriy)
MAX_RESULTS=20      # bitta javobda eng ko'pi bilan nechta telefon (top 20 uchun)
RATE_MAX=15         # RATE_WINDOW ichida ruxsat etilgan so'rov soni
RATE_WINDOW=60      # rate limit oynasi (soniya)
DAILY_LIMIT=5       # admin bo'lmagan foydalanuvchi uchun UTC+5 bo'yicha kunlik limit

# Off-topic himoyasi (ixtiyoriy, /settings orqali ham o'zgartiriladi)
OFF_TOPIC_BLOCK_MINUTES=60   # mavzuga aloqasiz so'rov uchun bloklash davomiyligi (daqiqa)
OFF_TOPIC_MAX_ATTEMPTS=2     # nechanchi ketma-ket off-topic urinish bloklaydi
